# 日付別ログ(<date>.log)を持つディレクトリ。複数指定可（すべて同じ形式である前提）
target:
  - .claude/skills/skill-audit/logs/commands

# 集計対象とする期間（日数）
lookback_days: 30

# 通知する最低スコア
min_score: 4

# 既存資産として照合する場所
existing_assets:
  skills:
    - ~/.claude/skills
    - .claude/skills
  cli:
    - ./**/scripts
  rules:
    - CLAUDE.md
    - AGENTS.md
    - docs/agent/
